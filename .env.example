# FloodAlert NG Environment Variables

# OpenWeatherMap API Key (get from https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Base RPC URL (for Base blockchain integration)
BASE_RPC_URL=https://mainnet.base.org

# Farcaster API Keys (optional, for enhanced social features)
FARCASTER_API_KEY=your_farcaster_api_key_here
FARCASTER_SECRET=your_farcaster_secret_here

# Next.js Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000

